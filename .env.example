# ─────────────────────────────────────────────
#  Casa Kura Chat — Configuración de entorno
# ─────────────────────────────────────────────
#
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas el archivo .env al repositorio.
#
#  cp .env.example .env

# API Key de Anthropic
# Obtén la tuya en: https://console.anthropic.com/settings/keys
VITE_ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# (Opcional) Modelo de Claude a utilizar
# Opciones disponibles: claude-opus-4-7 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
VITE_CLAUDE_MODEL=claude-opus-4-7

# (Opcional) Máximo de tokens en la respuesta
VITE_MAX_TOKENS=1024

# ─────────────────────────────────────────────
#  Notas de seguridad
# ─────────────────────────────────────────────
#  • Esta configuración expone la API key en el navegador.
#  • Apta SOLO para uso interno / demos protegidos.
#  • Para producción pública, crea un backend proxy que
#    maneje las llamadas a la API sin exponer la key.
# ─────────────────────────────────────────────
