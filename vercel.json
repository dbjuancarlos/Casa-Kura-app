{
    "version": 2,
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "env": {
          "VITE_ANTHROPIC_API_KEY": "@VITE_ANTHROPIC_API_KEY",
          "VITE_CLAUDE_MODEL": "claude-opus-4-7",
          "VITE_MAX_TOKENS": "1024"
    },
    "headers": [
          {
                  "source": "/api/(.*)",
                  "headers": [
                            {
                                        "key": "Cache-Control",
                                        "value": "no-store"
                            }
                  ]
          }
    ]
}
